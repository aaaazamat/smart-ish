# ─────────────────────────────────────────────
# DJANGO
# ─────────────────────────────────────────────
# Production'da yangi SECRET_KEY hosil qiling:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-CHANGE-ME-IN-PRODUCTION
DEBUG=True
ALLOWED_HOSTS=*

# CORS (vergul bilan ajratilgan ro'yxat)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_ALL_ORIGINS=True

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
# DEV: bo'sh qoldiring, SQLite ishlatiladi
# PROD: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# ─────────────────────────────────────────────
# EMAIL — OTP yetkazib berish
# ─────────────────────────────────────────────
# DEV: konsol backend (kod terminalga chiqadi)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@diplom.local
# Frontend domeni — email'lardagi havolalar uchun
FRONTEND_URL=http://localhost:5173

# PROD uchun Brevo (300 email/kun bepul):
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#   EMAIL_HOST_USER=your_brevo_login
#   EMAIL_HOST_PASSWORD=your_brevo_smtp_key

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_ACCESS_LIFETIME_HOURS=2
JWT_REFRESH_LIFETIME_DAYS=30

# ─────────────────────────────────────────────
# CACHE — bo'sh qoldirsangiz LocMem ishlatiladi
# Redis ishlatish uchun: REDIS_URL=redis://localhost:6379/1
# ─────────────────────────────────────────────
REDIS_URL=

# ─────────────────────────────────────────────
# OTP
# ─────────────────────────────────────────────
OTP_CODE_LIFETIME_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60

# ─────────────────────────────────────────────
# AI — Google Gemini (bepul tier)
# https://aistudio.google.com/apikey — kalit oling
# ─────────────────────────────────────────────
GEMINI_API_KEY=

# ─────────────────────────────────────────────
# Cloudflare R2 — media fayllar (avatar, logo)
# https://dash.cloudflare.com/?to=/:account/r2 — bucket yarating
# ─────────────────────────────────────────────
USE_R2=False
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-<bucket-hash>.r2.dev
