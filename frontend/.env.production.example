# Vercel deploy paytida shu environment variable'larni dashboard'da
# kiritamiz. Frontend HTTPS muhiti uchun:
#
# Project Settings > Environment Variables > Add new

# Render backend URL — `/api` suffix bilan
VITE_API_URL=https://osonish-backend.onrender.com/api

# WebSocket URL (avtomatik aniqlanadi VITE_API_URL'dan, lekin override mumkin)
# VITE_WS_URL=wss://osonish-backend.onrender.com
